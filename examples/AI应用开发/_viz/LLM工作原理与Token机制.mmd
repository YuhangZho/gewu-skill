flowchart TD
  raw_text["▣ 原始文本"]
  tokenizer["⚙ 分词器BPE"]
  token_ids["▣ Token ID序列"]
  ctx_window["⛔ 上下文窗口"]
  model["⚙ Transformer模型"]
